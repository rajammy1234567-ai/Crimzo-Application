{
  "expo": {
    "name": "Crimzo",
    "slug": "crimzo",
    "version": "4.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/CRIMZO_ICON.png",
    "scheme": "crimzo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crimzolive",
      "associatedDomains": [
        "applinks:www.crimzo.live",
        "applinks:crimzo.live"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Record reels and broadcast live video",
        "NSMicrophoneUsageDescription": "Record audio for reels and live streams",
        "NSPhotoLibraryUsageDescription": "Create reels from gallery and add music",
        "NSPhotoLibraryAddUsageDescription": "Save your created reels",
        "NSLocationWhenInUseUsageDescription": "Show nearby live streams and people"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/CRIMZO_ICON.png",
        "backgroundColor": "#000000"
      },
      "package": "com.crimzolive",
      "versionCode": 31,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_VIDEO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.crimzo.live",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "crimzo.live",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "www.crimzo.live",
              "pathPrefix": "/live"
            },
            {
              "scheme": "https",
              "host": "crimzo.live",
              "pathPrefix": "/live"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/crimzo_logo1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Record reels and broadcast live video"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Create reels from gallery and add music"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/crimzo_logo_header.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-video",
      "./plugins/withRemoveForegroundService",
      "./plugins/withAgoraExclude"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3494a0fa-1301-44ba-9bc4-4ff2d26f2c02"
      }
    },
    "owner": "dev_eas_office_viz001"
  }
}
