NODE_ENV=development
PORT=5001

# Production (Render): set in dashboard env vars
# PUBLIC_BASE_URL=https://crimzo-application-backend.onrender.com
# Local dev — your PC WiFi IP (run ipconfig on Windows)
PUBLIC_BASE_URL=http://192.168.1.7:5001

JWT_SECRET=change_me_to_a_long_random_string

# Email (optional)
SMTP_EMAIL=
SMTP_PASSWORD=

# Agora live streaming
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# MongoDB Atlas
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/crimzo

# Cloudinary — stories, reels, avatars upload to Cloudinary when set (else local ./uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay (wallet top-up: UPI / Card / Net Banking) ──
# Dashboard: https://dashboard.razorpay.com/app/keys
# Use Test Mode keys for development (rzp_test_... + secret)
# NEVER commit real keys — copy this file to .env and fill values there
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# RazorpayX Payouts (real withdrawals to bank/UPI)
# Dashboard: RazorpayX → My Account & Settings → Banking → Customer Identifier
RAZORPAY_X_ACCOUNT_NUMBER=your_razorpayx_customer_identifier
# Webhook secret from RazorpayX → Webhooks (payout events)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret




